{
  "name": "translite",
  "version": "0.1.0",
  "description": "A lightweight desktop translator with local models, online LLM providers, and a global quick-open shortcut.",
  "main": "src/main.js",
  "scripts": {
    "build": "vite build",
    "prestart": "npm run build",
    "start": "electron .",
    "dev": "vite --host 127.0.0.1",
    "lint": "node --check src/main.js && node --check src/preload.js && node --check src/localTranslator.node.js",
    "build:icons": "node scripts/build-icons.js",
    "pack:win": "npm run build && electron-builder --win --x64",
    "pack:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "release:win": "npm run build && electron-builder --win --x64 --publish always",
    "release:mac": "npm run build && electron-builder --mac --x64 --arm64 --publish always"
  },
  "keywords": [
    "electron",
    "translator",
    "desktop",
    "local-translation",
    "llm",
    "vue"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "png2icons": "^2.0.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.2",
    "@huggingface/transformers": "^4.2.0",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.3.9",
    "lucide-vue-next": "^0.577.0",
    "naive-ui": "^2.44.1",
    "vue": "^3.5.35"
  },
  "overrides": {
    "@codemirror/autocomplete": "6.18.7",
    "@codemirror/commands": "6.8.1",
    "@codemirror/search": "6.5.11"
  },
  "build": {
    "appId": "com.translite.app",
    "productName": "TransLite",
    "copyright": "Copyright © 2026 TransLite",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/main.js",
      "src/preload.js",
      "src/localTranslator.node.js",
      "src/renderer/assets/**",
      "dist/renderer/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/onnxruntime-node/**",
      "**/node_modules/sharp/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TransLite",
      "uninstallDisplayName": "TransLite ${version}",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": null
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "guoziyangnb",
        "repo": "translite",
        "releaseType": "release"
      }
    ]
  }
}
