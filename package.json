{
  "name": "translite",
  "version": "0.1.0",
  "description": "A lightweight desktop translator with local models, online LLM providers, and a global quick-open shortcut.",
  "main": "src/main.js",
  "scripts": {
    "build": "vite build",
    "prestart": "npm run build",
    "start": "electron .",
    "dev": "vite --host 127.0.0.1",
    "lint": "node --check src/main.js && node --check src/preload.js && node --check src/localTranslator.node.js"
  },
  "keywords": [
    "electron",
    "translator",
    "desktop",
    "local-translation",
    "llm",
    "vue"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^31.7.7",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.2",
    "@huggingface/transformers": "^4.2.0",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "lucide-vue-next": "^0.577.0",
    "naive-ui": "^2.44.1",
    "vue": "^3.5.35"
  },
  "overrides": {
    "@codemirror/autocomplete": "6.18.7",
    "@codemirror/commands": "6.8.1",
    "@codemirror/search": "6.5.11"
  }
}
